# ─────────────────────────────────────────────────────────────────────────────
# Shinda 24/7 — Environment Variables
# Copy this file to .env and fill in the values before starting the server.
# Lines beginning with # are comments and are ignored.
# ─────────────────────────────────────────────────────────────────────────────


# ── Server ────────────────────────────────────────────────────────────────────

# Port the Express API server listens on.
PORT=3000

# Secret used to sign and verify JWT tokens.
# Use a long random string in production: `openssl rand -hex 32`
JWT_SECRET=change-me-in-production


# ── Database ──────────────────────────────────────────────────────────────────
# On Replit this is provisioned automatically. On Docker / bare metal supply it
# as a single connection string OR as individual components (Drizzle accepts both).

DATABASE_URL=postgresql://user:password@localhost:5432/shinda247

# Individual components (used if DATABASE_URL is not set)
# PGHOST=localhost
# PGPORT=5432
# PGUSER=shinda
# PGPASSWORD=change-me
# PGDATABASE=shinda247


# ── M-Pesa (Safaricom Daraja) ─────────────────────────────────────────────────
# Leave blank during development — the server automatically falls back to a
# mock implementation that logs instead of making real API calls.
# Required for real deposits and withdrawals in production.

# App credentials from https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=

# STK Push (C2B) — the paybill or till number players pay into
MPESA_SHORTCODE=174379
MPESA_PASSKEY=

# B2C — the shortcode used for withdrawals (can be the same as above)
MPESA_B2C_SHORTCODE=

# Public HTTPS URL the Daraja API will POST callbacks to.
# Must be reachable from the internet (use ngrok for local dev).
MPESA_CALLBACK_BASE_URL=https://your-domain.com

# "sandbox" for testing, "production" for live transactions
MPESA_ENVIRONMENT=sandbox


# ── SMS / OTP (Africa's Talking) ─────────────────────────────────────────────
# Leave blank during development — OTP codes are logged to the console instead.
# Required for phone-based registration and login in production.

# Credentials from https://account.africastalking.com
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=sandbox

# Sender ID shown on the player's phone (must be approved by AT in production)
AFRICASTALKING_SENDER_ID=SHINDA247


# ── Firebase (optional — RTDB broadcaster) ────────────────────────────────────
# Only needed if you use Firebase Realtime Database as an additional broadcast
# channel. Socket.io works without this.

# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
# FIREBASE_DATABASE_URL=
